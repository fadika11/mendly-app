{
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.gradle": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.gradle": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.gradle/**": true
  },
  "java.import.exclusions": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.git/**",
    "**/.idea/**",
    "**/.gradle/**"
  ],
  "java.project.explorer.showNonJavaResources": false,
  "java.errors.incompleteClasspath.severity": "ignore"
}