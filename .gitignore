###################################
# Root .gitignore for Mendly app
# React + Vite + Capacitor Android + FastAPI + SQL Server
###################################

# =========================================================
# Node / JavaScript / React
# =========================================================
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# React / Vite build outputs
react-app/dist/
react-app/build/
react-app/.vite/
**/.vite/
.cache/

# TypeScript / JS coverage
coverage/
.nyc_output/
jest-cache/
jest-stare/
*.lcov
*.tsbuildinfo

# =========================================================
# Python / FastAPI
# =========================================================
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.eggs/
dist/
build/
htmlcov/
.coverage
.coverage*
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/

# Python virtual environments
.venv/
venv/
env/

# =========================================================
# Environment files / secrets
# Keep only .env.example files
# =========================================================
.env
.env.*
!.env.example

react-app/.env
react-app/.env.*
!react-app/.env.example

server/.env
server/.env.*
!server/.env.example

.envrc

# Firebase / private keys
server/firebase-key.json
firebase-key.json
*.pem
*.key
*.p12

# =========================================================
# Android / Capacitor generated files
# =========================================================
react-app/android/.gradle/
react-app/android/build/
react-app/android/app/build/
react-app/android/app/release/
react-app/android/app/debug/
react-app/android/local.properties
react-app/android/.idea/

# Android signing keys - DO NOT upload
*.jks
*.keystore
*.keystore.properties
key.properties

# Android Studio / Gradle temporary files
.gradle/
captures/
.externalNativeBuild/
.cxx/

# =========================================================
# Uploaded user data / runtime files
# =========================================================
media/
uploads/
tmp/
temp/

# =========================================================
# Large AI model / cache folders
# =========================================================
pretrained_models/
wav2vec2_checkpoints/
models_cache/
huggingface_cache/

# =========================================================
# SQL Server database artifacts
# =========================================================
*.mdf
*.ldf
*.ndf
*.bak
*.trn

# Keep your schema SQL file
!mendly_schema.sql

# =========================================================
# Logs & runtime data
# =========================================================
logs/
*.log
pids
*.pid
*.seed
*.pid.lock
node_repl_history

# =========================================================
# OS files
# =========================================================
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
Desktop.ini

# =========================================================
# Editors / IDEs
# =========================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml

# =========================================================
# Tooling / misc
# =========================================================
.direnv
firebase-debug.log
*.local
*.orig